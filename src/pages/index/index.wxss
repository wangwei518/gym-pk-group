.hero {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background: linear-gradient(135deg, #111827, #2563eb);
  color: #fff;
  margin-bottom: 24rpx;
}

.hero__title {
  font-size: 44rpx;
  font-weight: 700;
}

.hero__subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

.stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24rpx;
}

.stats__item {
  min-height: 180rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 12rpx;
}

.stats__value {
  font-size: 52rpx;
  font-weight: 700;
  color: #2563eb;
}

.stats__label {
  color: #6b7280;
}
