<view class="container checkin-page">
  <view class="card">
    <view class="section-title">记录今天的运动</view>
    <view class="section-subtitle">仅支持当天打卡，不支持补录</view>
  </view>

  <sport-tabs tabs="{{sportTabs}}" current="{{type}}" bind:change="onTypeChange" />

  <view class="card input-card">
    <view class="input-title">输入运动量</view>
    <input class="input" type="digit" placeholder="请输入运动量" value="{{value}}" bindinput="onValueInput" />
    <view class="input-hint" wx:if="{{type === 'run'}}">跑步支持 1 位小数，例如 3.5</view>
    <view class="input-hint" wx:else>当前项目仅支持正整数</view>
  </view>

  <button class="primary-button" bindtap="submit" loading="{{loading}}">提交打卡</button>
</view>
