.me-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.profile-card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.profile-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24rpx;
}

.edit-button {
  margin: 0;
  background: #ecf3ff;
  color: #2563eb;
  border-radius: 999rpx;
  font-size: 24rpx;
  padding: 0 24rpx;
}

.stats-grid {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.stats-item {
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  color: #fff;
}

.accent-blue { background: linear-gradient(135deg, #2563eb, #60a5fa); }
.accent-green { background: linear-gradient(135deg, #059669, #34d399); }
.accent-purple { background: linear-gradient(135deg, #7c3aed, #a78bfa); }
.accent-orange { background: linear-gradient(135deg, #ea580c, #fb923c); }

.stats-value {
  font-size: 42rpx;
  font-weight: 700;
}

.stats-label {
  opacity: 0.9;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e5e7eb;
}

.record-main {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.record-type {
  font-weight: 600;
}

.record-date {
  font-size: 24rpx;
  color: #6b7280;
}

.record-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #2563eb;
}
