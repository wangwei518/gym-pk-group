<view class="container auth-page">
  <view class="card auth-card">
    <view class="section-title">先完善一下你的资料</view>
    <view class="section-subtitle">头像和昵称会用于排行榜和个人页展示</view>

    <button class="avatar-button" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
      <image wx:if="{{avatarUrl}}" class="avatar-image" src="{{avatarUrl}}" mode="aspectFill" />
      <text wx:else>选择微信头像</text>
    </button>

    <input class="nickname-input" type="nickname" placeholder="请输入微信昵称" bindinput="onNicknameInput" value="{{nickName}}" />
  </view>

  <button class="primary-button" bindtap="submitProfile" loading="{{loading}}">完成并进入</button>
</view>
