.ranking-item {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #e5e7eb;
}

.ranking-item--self {
  background: rgba(37, 99, 235, 0.06);
  border-radius: 20rpx;
  padding: 24rpx;
}

.ranking-item__header {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: center;
  margin-bottom: 12rpx;
}

.ranking-item__left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
}

.ranking-item__rank {
  width: 64rpx;
  font-weight: 700;
  color: #2563eb;
}

.ranking-item__avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #dbeafe;
  color: #1d4ed8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}

.ranking-item__name {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ranking-item__value {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

.ranking-item__track {
  height: 16rpx;
  background: #e5e7eb;
  border-radius: 999rpx;
  overflow: hidden;
}

.ranking-item__bar {
  height: 100%;
  min-width: 8%;
  background: linear-gradient(90deg, #60a5fa, #2563eb);
}
